APP_NAME=AI-Admin
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# SQLite for local dev (zero setup)
# For Docker/PostgreSQL, change to:
#   postgresql+asyncpg://aiadmin:aiadmin123@localhost:5432/aiadmin
DATABASE_URL=sqlite+aiosqlite:///./aiadmin.db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

AI_ENABLED=true
AI_PROVIDER=deepseek
AI_API_KEY=sk-your-deepseek-api-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1

FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=./storage
FILE_MAX_SIZE_MB=10

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
